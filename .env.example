# Copy to .env.local and fill in. Leads still work without these (logged
# server-side), but won't be emailed until RESEND_API_KEY is set.

# Production site URL — used for canonical, OG, robots, sitemap.
NEXT_PUBLIC_SITE_URL=https://ourbrio.com

# Lead email delivery (https://resend.com → API Keys)
RESEND_API_KEY=
# Inbox that receives leads (defaults to info@ourbrio.com)
LEAD_TO_EMAIL=info@ourbrio.com
# Verified Resend sender. Until you verify a domain, Resend's test sender
# (onboarding@resend.dev) only delivers to your own account email.
LEAD_FROM_EMAIL="OurBrio <onboarding@resend.dev>"
